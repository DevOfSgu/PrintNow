@model List<PrintNow.Web.Services.OnlineUserInfo>
@{
    ViewData["Title"] = "Người dùng online";
    Layout = "_AdminLayout";
}

<style>
    .online-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }
    .online-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #dcfce7;
        color: #166534;
        border-radius: 999px;
        padding: 4px 14px;
        font-size: 13px;
        font-weight: 600;
    }
    .online-badge .pulse-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #16a34a;
        animation: pulse 1.5s infinite;
        flex-shrink: 0;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }
    .users-table-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .users-table-header {
        padding: 20px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .users-table th {
        background: #f8fafc;
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 12px 16px;
        border-bottom: 1px solid #e2e8f0;
        border-top: none;
        white-space: nowrap;
    }
    .users-table td {
        padding: 14px 16px;
        vertical-align: middle;
        border-color: #f1f5f9;
        font-size: 13.5px;
    }
    .users-table tbody tr {
        transition: background-color 0.2s;
    }
    .users-table tbody tr:hover {
        background-color: #fafafa;
    }
    .users-table tbody tr.new-row {
        animation: rowFadeIn 0.5s ease-out;
    }
    .users-table tbody tr.leaving-row {
        animation: rowFadeOut 0.4s ease-in forwards;
    }
    @@keyframes rowFadeIn {
        from { background-color: #dcfce7; opacity: 0; }
        to { background-color: transparent; opacity: 1; }
    }
    @@keyframes rowFadeOut {
        from { opacity: 1; transform: translateX(0); }
        to { opacity: 0; transform: translateX(-20px); }
    }
    .user-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D62839, #ef4444);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
        font-size: 13px;
        flex-shrink: 0;
    }
    .user-avatar.guest {
        background: linear-gradient(135deg, #94a3b8, #64748b);
    }
    .role-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 10px;
        border-radius: 999px;
    }
    .role-badge.admin { background: #fee2e2; color: #dc2626; }
    .role-badge.shopowner { background: #fef3c7; color: #d97706; }
    .role-badge.customer { background: #dbeafe; color: #2563eb; }
    .role-badge.guest { background: #f1f5f9; color: #64748b; }
    .url-cell {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 12px;
        color: #64748b;
    }
    .ua-cell {
        max-width: 160px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 12px;
        color: #64748b;
    }
    .empty-state {
        text-align: center;
        padding: 60px 24px;
        color: #94a3b8;
    }
    .empty-state i { font-size: 48px; margin-bottom: 16px; display: block; }
    .pagination-wrapper {
        padding: 16px 24px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
    }
    .pagination-info { font-size: 13px; color: #64748b; }
    .page-link {
        border-radius: 8px !important;
        font-size: 13px;
        padding: 6px 12px;
        color: #374151;
        border-color: #e2e8f0;
    }
    .page-item.active .page-link {
        background-color: var(--primary) !important;
        border-color: var(--primary) !important;
        color: white !important;
    }
    .page-link:hover {
        background-color: #f1f5f9;
        border-color: #e2e8f0;
        color: #374151;
    }
    .refresh-btn {
        font-size: 12px;
        padding: 6px 14px;
        border-radius: 8px;
        font-weight: 600;
    }
    .total-counter {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
    }
</style>

<div class="online-header">
    <div>
        <h3 class="fw-bold m-0">Người dùng đang truy cập</h3>
        <p class="text-muted small m-0 mt-1">Theo dõi real-time tất cả phiên truy cập đang hoạt động trên hệ thống</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <span class="online-badge">
            <span class="pulse-dot"></span>
            <span id="totalOnlineCount">@Model.Count</span> đang online
        </span>
    </div>
</div>

<div class="users-table-card">
    <div class="users-table-header">
        <i class="bi bi-wifi text-success fs-5"></i>
        <span class="fw-bold" style="font-size: 15px;">Danh sách phiên truy cập</span>
        <span class="ms-auto text-muted small" id="lastUpdated">Cập nhật mới nhất: vừa xong</span>
    </div>

    <div class="table-responsive">
        <table class="table users-table mb-0">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Thời gian truy cập</th>
                </tr>
            </thead>
            <tbody id="onlineUsersBody">
                @{
                    var uniqueLatestUsers = Model
                        .GroupBy(u => u.UserId != null ? "id_" + u.UserId : (!string.IsNullOrEmpty(u.Email) ? "em_" + u.Email : "conn_" + u.ConnectionId))
                        .Select(g => g.OrderByDescending(u => u.ConnectedAt).First())
                        .OrderByDescending(u => u.ConnectedAt)
                        .ToList();
                }
                @if (!uniqueLatestUsers.Any())
                {
                    <tr id="emptyRow">
                        <td colspan="2">
                            <div class="empty-state">
                                <i class="bi bi-people"></i>
                                <h6 class="fw-bold">Chưa có người dùng nào đang truy cập</h6>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var user in uniqueLatestUsers)
                    {
                        var initial = string.IsNullOrEmpty(user.FullName) ? "?" : user.FullName.Substring(0, 1).ToUpper();
                        var isGuest = user.UserId == null;
                        <tr data-conn="@user.ConnectionId" data-userid="@user.UserId" data-email="@user.Email">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar @(isGuest ? "guest" : "")">@initial</div>
                                    <div>
                                        <div class="fw-bold" style="font-size: 13.5px;">@user.FullName</div>
                                        <div class="text-muted" style="font-size: 11px;">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td style="white-space: nowrap; font-size: 13.5px; color: #64748b;">@user.ConnectedAt.ToLocalTime().ToString("HH:mm:ss dd/MM/yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        // Map connectionId => row data object
        let usersMap = new Map();

        // Seed initial data from server render
        document.querySelectorAll('#onlineUsersBody tr[data-conn]').forEach(function(row) {
            usersMap.set(row.dataset.conn, {
                connectionId: row.dataset.conn,
                fullName: row.querySelector('.fw-bold')?.innerText || '',
                email: row.querySelector('.text-muted')?.innerText || '',
                connectedAt: row.querySelector('td:last-child')?.innerText || '',
                userId: row.dataset.userid || null,
                timestamp: Date.now()
            });
        });

        function buildRow(u) {
            const isGuest = !u.userId;
            const initial = u.fullName && u.fullName.length > 0 ? u.fullName[0].toUpperCase() : '?';
            return `
                <tr data-conn="${escapeAttr(u.connectionId)}" data-userid="${escapeAttr(u.userId || '')}" data-email="${escapeAttr(u.email || '')}">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="user-avatar ${isGuest ? 'guest' : ''}">${initial}</div>
                            <div>
                                <div class="fw-bold" style="font-size:13.5px;">${escapeHtml(u.fullName || 'Khách vãng lai')}</div>
                                <div class="text-muted" style="font-size:11px;">${escapeHtml(u.email || 'N/A')}</div>
                            </div>
                        </div>
                    </td>
                    <td style="white-space:nowrap;font-size:13.5px;color:#64748b;">${escapeHtml(u.connectedAt || '')}</td>
                </tr>`;
        }

        function renderTable() {
            const tbody = document.getElementById('onlineUsersBody');
            const allUsers = Array.from(usersMap.values());
            
            // Sort by timestamp descending so the most recent is first
            allUsers.sort((a, b) => b.timestamp - a.timestamp);

            // Group by user identity to keep unique users
            const uniqueUsers = new Map();
            for (const u of allUsers) {
                const key = u.userId ? 'id_' + u.userId : (u.email ? 'em_' + u.email : 'conn_' + u.connectionId);
                if (!uniqueUsers.has(key)) {
                    uniqueUsers.set(key, u);
                }
            }

            const uniqueList = Array.from(uniqueUsers.values());
            const total = uniqueList.length;
            document.getElementById('totalOnlineCount').innerText = total;
            document.getElementById('lastUpdated').innerText = 'Cập nhật: ' + new Date().toLocaleTimeString('vi-VN');

            if (total === 0) {
                tbody.innerHTML = `<tr id="emptyRow"><td colspan="2"><div class="empty-state"><i class="bi bi-people"></i><h6 class="fw-bold">Chưa có người dùng nào đang truy cập</h6></div></td></tr>`;
                return;
            }

            let html = '';
            uniqueList.forEach(function(u) {
                html += buildRow(u);
            });
            tbody.innerHTML = html;
        }

        function escapeHtml(text) {
            if (!text) return '';
            return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
        function escapeAttr(text) {
            if (!text) return '';
            return text.replace(/"/g,'&quot;');
        }

        // Connect to UserTrackingHub as Admin
        const adminConnection = new signalR.HubConnectionBuilder()
            .withUrl("/userTrackingHub?currentUrl=" + encodeURIComponent(window.location.href))
            .withAutomaticReconnect()
            .build();

        adminConnection.on("UserConnected", function(info) {
            if (!info || !info.connectionId) return;
            const u = {
                connectionId: info.connectionId,
                userId: info.userId,
                fullName: info.fullName,
                email: info.email,
                role: info.role,
                ipAddress: info.ipAddress,
                userAgent: info.userAgent,
                currentUrl: info.currentUrl,
                connectedAt: info.connectedAt ? new Date(info.connectedAt).toLocaleTimeString('vi-VN') + ' ' + new Date(info.connectedAt).toLocaleDateString('vi-VN') : '',
                timestamp: info.connectedAt ? new Date(info.connectedAt).getTime() : Date.now()
            };
            usersMap.set(u.connectionId, u);
            renderTable();
        });

        adminConnection.on("UserDisconnected", function(connectionId) {
            if (!connectionId) return;
            usersMap.delete(connectionId);
            renderTable();
        });

        adminConnection.start().then(function() {
            return adminConnection.invoke("RegisterAdmin");
        }).catch(function(err) {
            console.error("Admin tracking connection error:", err);
        });
    </script>
}
