<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrintNow Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrintNow.Web.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: var(--secondary-container);
            margin: 0;
            overflow-x: hidden;
        }
        .admin-layout {
            display: flex;
            min-height: 100vh;
        }
        .admin-sidebar {
            width: 250px;
            background-color: white;
            box-shadow: 2px 0 10px rgba(0,0,0,0.03);
            display: flex;
            flex-direction: column;
            padding: 24px 0;
            z-index: 10;
        }
        .admin-sidebar-header {
            padding: 12px 24px 0;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .admin-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 0 16px;
            flex-grow: 1;
        }
        .admin-nav a {
            color: var(--on-surface-variant);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            padding: 12px 16px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s;
        }
        .admin-nav a:hover {
            background-color: var(--surface-container-low);
        }
        .admin-nav a.active {
            color: var(--primary);
            background-color: var(--secondary-container);
        }
        .admin-nav a i {
            width: 20px;
            text-align: center;
            color: var(--on-surface-variant);
        }
        .admin-nav a.active i {
            color: var(--primary);
        }
        .admin-main {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }
        .admin-main-content {
            padding: 32px;
            max-width: 1600px;
            width: 100%;
            margin: 0 auto;
            flex-grow: 1;
        }
        .admin-sidebar-footer {
            padding: 16px;
            border-top: 1px solid #f1f5f9;
            margin-top: auto;
        }
        .admin-profile-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .admin-profile-name {
            font-size: 13.5px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 2px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .admin-profile-role {
            font-size: 11px;
            color: #64748b;
        }
        .admin-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            font-weight: 700;
            background-color: var(--secondary-container);
            border: 1px solid #fca5a5;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 14px;
            flex-shrink: 0;
        }
        .btn-logout-sidebar {
            color: #ef4444;
            background-color: #fef2f2;
            border: 1px solid #fee2e2;
            font-size: 12px;
            font-weight: 600;
            padding: 8px;
            border-radius: 8px;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 12px;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-logout-sidebar:hover {
            background-color: #fee2e2;
            color: #b91c1c;
        }
    </style>
</head>
<body>
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="admin-sidebar-header">
                <a href="/Admin/Index">
                    <img src="~/logoapp.png" alt="PrintNow" style="height: 36px; object-fit: contain;" />
                </a>
            </div>
            <nav class="admin-nav">
                <a href="/Admin/Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Tổng quan
                </a>
                <a href="/Admin/Shops" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Shops" ? "active" : "")">
                    <i class="bi bi-shop"></i> Quản lý tiệm
                </a>
                <a href="/Admin/PlatformFees" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "PlatformFees" ? "active" : "")">
                    <i class="bi bi-cash-coin"></i> Phí sàn
                </a>
                <a href="/Admin/Withdrawals" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Withdrawals" ? "active" : "")">
                    <i class="bi bi-bank"></i> Yêu cầu rút tiền
                </a>
            </nav>
            <div class="admin-sidebar-footer">
                <div class="admin-profile-info">
                    <div class="admin-avatar">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div class="flex-grow-1" style="min-width: 0;">
                        <div class="admin-profile-name">@User.Identity.Name</div>
                        <div class="admin-profile-role">Quản trị viên</div>
                    </div>
                </div>
                <a class="btn-logout-sidebar" asp-controller="Auth" asp-action="Logout">
                    <i class="bi bi-box-arrow-left"></i> Đăng xuất
                </a>
            </div>
        </aside>
        <main class="admin-main">
            <div class="admin-main-content">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
