@model IEnumerable<PrintNow.Web.Models.WithdrawalRequest>
@{
    ViewData["Title"] = "Admin - Yêu cầu rút tiền";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold m-0">Yêu cầu rút tiền</h3>
        <p class="text-muted small m-0 mt-1">Quản lý yêu cầu rút tiền từ các chủ tiệm</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid #e2e8f0;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small">
                    <tr>
                        <th class="border-0 ps-4">Tiệm in</th>
                        <th class="border-0">Số tiền</th>
                        <th class="border-0">Thông tin ngân hàng</th>
                        <th class="border-0">Trạng thái</th>
                        <th class="border-0">Ngày yêu cầu</th>
                        <th class="border-0 pe-4 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@w.Shop?.ShopName</td>
                            <td class="fw-bold text-danger">@w.Amount.ToString("N0")đ</td>
                            <td>
                                <div style="font-size: 13px;">
                                    <div><strong>@w.BankAccountName</strong></div>
                                    <div class="text-muted">@w.BankAccountNumber - @w.BankName</div>
                                </div>
                            </td>
                            <td>
                                @if (w.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                }
                                else if (w.Status == "Approved")
                                {
                                    <span class="badge bg-success">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Từ chối</span>
                                }
                            </td>
                            <td class="text-muted" style="font-size: 13px;">
                                @w.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="pe-4 text-end">
                                @if (w.Status == "Pending")
                                {
                                    <div class="d-flex gap-1 justify-content-end">
                                        <form asp-action="ApproveWithdrawal" method="post" class="d-inline" 
                                              onsubmit="return confirm('Xác nhận đã chuyển tiền cho chủ tiệm? Số dư sẽ được trừ tự động.')">
                                            <input type="hidden" name="id" value="@w.Id" />
                                            <button type="submit" class="btn btn-sm btn-success" style="border-radius: 8px;">
                                                <i class="bi bi-check-lg me-1"></i> Duyệt
                                            </button>
                                        </form>
                                        <form asp-action="RejectWithdrawal" method="post" class="d-inline" 
                                              onsubmit="return confirm('Từ chối yêu cầu này?')">
                                            <input type="hidden" name="id" value="@w.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 8px;">
                                                <i class="bi bi-x-lg me-1"></i> Từ chối
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">
                                        @(w.ProcessedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")
                                        @if (!string.IsNullOrEmpty(w.AdminNote))
                                        {
                                            <br/><em class="text-muted">Ghi chú: @w.AdminNote</em>
                                        }
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Chưa có yêu cầu rút tiền nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
