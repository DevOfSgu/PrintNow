<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrintNow</title>
    <script type="importmap"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrintNow.Web.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: #f5f5f5;
            margin: 0;
            overflow-x: hidden;
        }
        .customer-layout {
            display: flex;
            min-height: 100vh;
        }
        .customer-sidebar {
            width: 250px;
            background-color: white;
            box-shadow: 2px 0 10px rgba(0,0,0,0.03);
            display: flex;
            flex-direction: column;
            padding: 24px 0;
            z-index: 10;
        }
        .customer-sidebar-header {
            padding: 12px 24px 0;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .customer-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 0 16px;
            flex-grow: 1;
        }
        .customer-nav a {
            color: var(--on-surface-variant);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            padding: 12px 16px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s;
        }
        .customer-nav a:hover {
            background-color: var(--surface-container-low);
        }
        .customer-nav a.active {
            color: var(--primary);
            background-color: var(--secondary-container);
        }
        .customer-nav a.active svg {
            color: var(--primary);
        }
        .customer-nav svg {
            width: 20px;
            height: 20px;
            color: var(--on-surface-variant);
        }
        .customer-sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid #E5E5E5;
        }
        .customer-main {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }
        .customer-topbar {
            padding: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .customer-icons {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .customer-icons svg {
            width: 24px;
            height: 24px;
            color: var(--on-surface-variant);
            cursor: pointer;
        }
        .customer-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: #d1d5db;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
            overflow: hidden;
            cursor: pointer;
        }
        .customer-content {
            padding: 0 24px 32px 24px;
            max-width: 1600px;
            width: 100%;
            margin: 0 auto;
            flex-grow: 1;
        }

        /* Chatbot Style */
        .chatbot-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
        }
        .chatbot-toggle {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background-color: var(--primary);
            border: none;
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
        }
        .chatbot-toggle:hover {
            transform: scale(1.1);
            background-color: #b91c1c;
            box-shadow: 0 6px 20px rgba(185,28,28,0.3);
        }
        .chatbot-window {
            position: absolute;
            bottom: 72px;
            right: 0;
            width: 360px;
            height: 500px;
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            border: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: chatbotAppear 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @@keyframes chatbotAppear {
            from {
                opacity: 0;
                transform: translateY(20px) scale(0.9);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        .chatbot-header {
            background-color: var(--primary);
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: white;
        }
        .chatbot-messages {
            flex-grow: 1;
            padding: 16px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background-color: #f8fafc;
        }
        .chatbot-msg {
            max-width: 85%;
            padding: 10px 14px;
            border-radius: 12px;
            font-size: 13px;
            line-height: 1.5;
            word-wrap: break-word;
        }
        .chatbot-msg.bot {
            background-color: white;
            color: #1e293b;
            align-self: flex-start;
            border: 1px solid #e2e8f0;
            border-bottom-left-radius: 4px;
        }
        .chatbot-msg.user {
            background-color: var(--primary);
            color: white;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }
        .chatbot-input-container {
            padding: 12px;
            border-top: 1px solid #e2e8f0;
            display: flex;
            gap: 8px;
            background-color: white;
        }
        .chatbot-input {
            border-radius: 20px;
            font-size: 13.5px;
            padding-left: 16px;
            border: 1px solid #cbd5e1;
        }
        .chatbot-input:focus {
            box-shadow: none;
            border-color: var(--primary);
        }
        .btn-send-chatbot {
            border-radius: 50%;
            width: 38px;
            height: 38px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
    </style>
</head>
<body>
    <div class="customer-layout">
        <!-- Hamburger button for mobile -->
        <button class="mobile-hamburger" id="mobileSidebarToggle" aria-label="Toggle menu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
        <!-- Sidebar overlay for mobile -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        <!-- Sidebar -->
        <aside class="customer-sidebar" id="customerSidebar">
            <div class="customer-sidebar-header">
                <a href="/Customer/Index">
                    <img src="~/logoapp.png" alt="PrintNow" style="height: 36px; object-fit: contain;" />
                </a>
            </div>
            <nav class="customer-nav">
                @{
                    var action = ViewContext.RouteData.Values["Action"]?.ToString();
                }
                <a href="/Customer/Index" class="@(new[] { "Index", "ShopDetail", "OrderConfig" }.Contains(action) ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    Khám phá
                </a>
                <a href="/Customer/Orders" class="@(action == "Orders" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    Đơn hàng
                </a>
                <a href="/Customer/Messages" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Messages" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    Tin nhắn
                </a>
                <a href="/Customer/Cart" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Cart" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                    Giỏ hàng
                </a>
            </nav>
            <div class="customer-sidebar-footer" style="padding: 16px; border-top: 1px solid #f1f5f9; margin-top: auto;">
                <div class="d-flex align-items-center gap-3">
                    <div class="customer-avatar" style="width: 36px; height: 36px; border-radius: 50%; font-weight: 700; background-color: var(--secondary-container); border: 1px solid #fca5a5; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 14px; flex-shrink: 0;">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                    <div class="flex-grow-1" style="min-width: 0;">
                        <div class="fw-bold text-dark text-truncate" style="font-size: 13.5px; margin-bottom: 2px;">@User.Identity.Name</div>
                        <div class="text-muted" style="font-size: 11px;">Khách hàng</div>
                    </div>
                </div>
                <a class="btn-logout-sidebar" asp-controller="Auth" asp-action="Logout" style="color: #ef4444; background-color: #fef2f2; border: 1px solid #fee2e2; font-size: 12px; font-weight: 600; padding: 8px; border-radius: 8px; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 12px; text-decoration: none; transition: all 0.2s;">
                    <i class="bi bi-box-arrow-left"></i> Đăng xuất
                </a>
            </div>
        </aside>

        <!-- Main Workspace -->
        <div class="customer-main">
            <!-- Page Content -->
            <main class="customer-content pt-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Floating Chatbot AI Widget -->
    <div class="chatbot-container" id="chatbotContainer">
        <!-- Floating Toggle Button -->
        <button class="chatbot-toggle" id="chatbotToggle" title="Trò chuyện với trợ lý ảo PrintNow AI">
            <i class="bi bi-robot fs-3 text-white"></i>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" style="font-size: 9px; padding: 3px 6px;">AI</span>
        </button>

        <!-- Chat Box Window -->
        <div class="chatbot-window" id="chatbotWindow" style="display: none;">
            <div class="chatbot-header">
                <div class="d-flex align-items-center gap-2">
                    <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                        <i class="bi bi-robot fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold text-white" style="font-size: 14px;">Trợ lý PrintNow AI</h6>
                        <span class="text-white-50" style="font-size: 10px;">Hoạt động 24/7</span>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" id="chatbotClose" aria-label="Close" style="font-size: 10px;"></button>
            </div>
            
            <div class="chatbot-messages" id="chatbotMessages">
                <div class="chatbot-msg bot">
                    Chào bạn! Tôi là Trợ lý AI của <strong>PrintNow</strong>. Tôi có thể hỗ trợ bạn tìm kiếm tiệm in, tư vấn khổ giấy A3/A4/A5, tính toán giá in, hoặc giải thích phí ship 20k nội thành. Bạn cần trợ giúp gì hôm nay?
                </div>
            </div>
            
            <div class="chatbot-input-container">
                <input type="text" class="form-control chatbot-input" id="chatbotInput" placeholder="Nhập câu hỏi..." autocomplete="off" />
                <button class="btn btn-primary btn-send-chatbot" id="chatbotSendBtn">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (navigator.geolocation && !sessionStorage.getItem("user_lat")) {
                navigator.geolocation.getCurrentPosition(function(position) {
                    sessionStorage.setItem("user_lat", position.coords.latitude);
                    sessionStorage.setItem("user_lng", position.coords.longitude);
                }, function(error) {
                    sessionStorage.setItem("user_lat", 10.762622);
                    sessionStorage.setItem("user_lng", 106.660172);
                });
            }

            var toggleBtn = document.getElementById("chatbotToggle");
            var closeBtn = document.getElementById("chatbotClose");
            var windowEl = document.getElementById("chatbotWindow");
            var inputEl = document.getElementById("chatbotInput");
            var sendBtn = document.getElementById("chatbotSendBtn");
            var messagesEl = document.getElementById("chatbotMessages");

            // Session history array in memory (not saved in database)
            var chatHistory = [];

            // Toggle visibility
            toggleBtn.addEventListener("click", function() {
                if (windowEl.style.display === "none") {
                    windowEl.style.display = "flex";
                    inputEl.focus();
                } else {
                    windowEl.style.display = "none";
                }
            });

            closeBtn.addEventListener("click", function() {
                windowEl.style.display = "none";
            });

            // Send message logic
            function sendMessage() {
                var text = inputEl.value.trim();
                if (!text) return;

                // Render user message
                appendMessage("user", text);
                inputEl.value = "";

                // Display typing loading indicator
                var loadingId = appendLoadingMessage();

                var payload = {
                    Message: text,
                    History: chatHistory
                };
                var savedLat = sessionStorage.getItem("user_lat");
                var savedLng = sessionStorage.getItem("user_lng");
                if (savedLat && savedLng) {
                    payload.Latitude = parseFloat(savedLat);
                    payload.Longitude = parseFloat(savedLng);
                }

                // Send to backend
                fetch('/Customer/ChatBot', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(payload)
                })
                .then(response => response.json())
                .then(data => {
                    removeLoadingMessage(loadingId);
                    appendMessage("bot", data.response);

                    // Add to session history
                    chatHistory.push({ Role: "user", Content: text });
                    chatHistory.push({ Role: "assistant", Content: data.response });

                    // Cap history size to recent 10 messages to save request size
                    if (chatHistory.length > 10) {
                        chatHistory = chatHistory.slice(chatHistory.length - 10);
                    }
                })
                .catch(error => {
                    removeLoadingMessage(loadingId);
                    appendMessage("bot", "Đã xảy ra lỗi kết nối với trợ lý AI. Vui lòng kiểm tra lại sau!");
                    console.error("Chatbot error:", error);
                });
            }

            sendBtn.addEventListener("click", sendMessage);
            inputEl.addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    sendMessage();
                }
            });

            function appendMessage(role, text) {
                var msgDiv = document.createElement("div");
                msgDiv.className = "chatbot-msg " + (role === "user" ? "user" : "bot");
                
                // Allow rich markdown bold formatting if returned
                var formatted = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                formatted = formatted.replace(/\n/g, '<br/>');
                msgDiv.innerHTML = formatted;
                
                messagesEl.appendChild(msgDiv);
                messagesEl.scrollTop = messagesEl.scrollHeight;
            }

            function appendLoadingMessage() {
                var loadingId = "loading_" + Date.now();
                var msgDiv = document.createElement("div");
                msgDiv.className = "chatbot-msg bot loading-msg";
                msgDiv.id = loadingId;
                msgDiv.innerHTML = '<span class="spinner-border spinner-border-sm text-secondary" role="status"></span> <span class="ms-1 small text-muted">AI đang nghĩ...</span>';
                messagesEl.appendChild(msgDiv);
                messagesEl.scrollTop = messagesEl.scrollHeight;
                return loadingId;
            }

            function removeLoadingMessage(id) {
                var el = document.getElementById(id);
                if (el) el.remove();
            }
        });

        // Mobile sidebar toggle
        const sidebarToggle = document.getElementById('mobileSidebarToggle');
        const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');
        const sidebarOverlay = document.getElementById('sidebarOverlay');
        const customerSidebar = document.getElementById('customerSidebar');

        if (sidebarToggle && sidebarOverlay && customerSidebar) {
            function openSidebar() {
                customerSidebar.classList.add('open');
                sidebarOverlay.classList.add('show');
                sidebarToggle.style.display = 'none';
                if (sidebarCloseBtn) sidebarCloseBtn.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
            function closeSidebar() {
                customerSidebar.classList.remove('open');
                sidebarOverlay.classList.remove('show');
                sidebarToggle.style.display = '';
                if (sidebarCloseBtn) sidebarCloseBtn.style.display = 'none';
                document.body.style.overflow = '';
            }
            sidebarToggle.addEventListener('click', function(e) {
                e.stopPropagation();
                if (customerSidebar.classList.contains('open')) {
                    closeSidebar();
                } else {
                    openSidebar();
                }
            });
            if (sidebarCloseBtn) {
                sidebarCloseBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    closeSidebar();
                });
            }
            sidebarOverlay.addEventListener('click', closeSidebar);
        }
    </script>
</body>
</html>
