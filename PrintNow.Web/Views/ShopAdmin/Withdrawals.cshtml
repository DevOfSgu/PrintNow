@model List<PrintNow.Web.Models.WithdrawalRequest>
@{
    ViewData["Title"] = "Yêu cầu rút tiền";
    Layout = "_ShopAdminLayout";
    var balance = ViewBag.ShopBalance as decimal? ?? 0;
    var bankAccountName = ViewBag.BankAccountName as string;
    var bankAccountNumber = ViewBag.BankAccountNumber as string;
    var bankName = ViewBag.BankName as string;
}

<style>
    .balance-card {
        background: linear-gradient(135deg, #D62839, #92001c);
        color: white;
        border-radius: 16px;
        padding: 28px;
    }
    .balance-amount {
        font-size: 36px;
        font-weight: 700;
    }
    .withdrawal-item {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
    }
</style>

<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="balance-card">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-wallet2 fs-4"></i>
                <span class="fw-semibold" style="opacity: 0.9;">Số dư khả dụng</span>
            </div>
            <div class="balance-amount">@balance.ToString("N0")đ</div>
            @if (!string.IsNullOrEmpty(bankAccountNumber))
            {
                <div class="mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.2);">
                    <div style="font-size: 12px; opacity: 0.8;">Tài khoản nhận:</div>
                    <div style="font-weight: 600; font-size: 13px;">@bankAccountName</div>
                    <div style="font-size: 13px;">@bankAccountNumber - @bankName</div>
                </div>
            }
            else
            {
                <div class="mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.2);">
                    <a href="/ShopAdmin/BankAccount" class="text-white fw-semibold" style="font-size: 13px;">
                        <i class="bi bi-plus-circle me-1"></i> Cập nhật tài khoản ngân hàng
                    </a>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(bankAccountNumber) && balance >= 200000)
        {
            <div class="card border-0 shadow-sm mt-4" style="border-radius: 16px; border: 1px solid #e2e8f0;">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Yêu cầu rút tiền</h6>
                    <form id="withdrawalForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold" style="font-size: 13px;">Số tiền muốn rút</label>
                            <div class="input-group">
                                <input type="number" id="withdrawalAmount" class="form-control" 
                                       min="200000" max="@((int)balance)" step="10000"
                                       value="200000" style="border-radius: 8px 0 0 8px;" />
                                <span class="input-group-text" style="border-radius: 0 8px 8px 0;">VNĐ</span>
                            </div>
                            <div class="text-muted small mt-1">Tối thiểu 200,000đ | Số dư: @balance.ToString("N0")đ</div>
                        </div>
                        <button type="submit" class="btn btn-danger fw-bold w-100" style="border-radius: 8px; padding: 12px;">
                            <i class="bi bi-send me-1"></i> Gửi yêu cầu
                        </button>
                    </form>
                </div>
            </div>
        }
        else if (balance < 200000 && balance > 0)
        {
            <div class="alert alert-info mt-4" style="border-radius: 12px;">
                <i class="bi bi-info-circle me-2"></i> Số dư chưa đủ để rút (tối thiểu 200,000đ).
            </div>
        }
    </div>

    <div class="col-12 col-lg-8">
        <h5 class="fw-bold mb-3">Lịch sử yêu cầu rút tiền</h5>
        
        <div class="d-flex flex-column gap-3">
            @foreach (var w in Model)
            {
                <div class="withdrawal-item">
                    <div>
                        <h6 class="fw-bold mb-1" style="font-size: 14px;">@w.Amount.ToString("N0")đ</h6>
                        <div class="text-muted" style="font-size: 12px;">
                            @w.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                        @if (!string.IsNullOrEmpty(w.AdminNote))
                        {
                            <div class="text-muted small mt-1">
                                <i class="bi bi-chat-text me-1"></i> @w.AdminNote
                            </div>
                        }
                    </div>
                    <div>
                        @if (w.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark px-3 py-2">Chờ duyệt</span>
                        }
                        else if (w.Status == "Approved")
                        {
                            <span class="badge bg-success px-3 py-2">Đã duyệt</span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-3 py-2">Từ chối</span>
                        }
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <span>Chưa có yêu cầu rút tiền nào.</span>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('withdrawalForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            var amount = parseFloat(document.getElementById('withdrawalAmount').value);
            
            if (!amount || amount < 200000) {
                alert('Số tiền rút tối thiểu là 200,000đ.');
                return;
            }
            if (amount > @((int)balance)) {
                alert('Số dư không đủ.');
                return;
            }

            var btn = this.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

            $.post('/ShopAdmin/RequestWithdrawal', { amount: amount }, function(response) {
                if (response.success) {
                    alert(response.message);
                    location.reload();
                } else {
                    alert(response.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send me-1"></i> Gửi yêu cầu';
                }
            }).fail(function() {
                alert('Lỗi kết nối. Vui lòng thử lại.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send me-1"></i> Gửi yêu cầu';
            });
        });
    </script>
}
