@model List<PrintNow.Web.Models.PlatformFee>
@{
    ViewData["Title"] = "Phí sàn";
    Layout = "_ShopAdminLayout";
    var isLocked = ViewBag.IsLocked as bool? ?? false;
    var checkoutUrl = ViewBag.CheckoutUrl as string;
    var qrCode = ViewBag.QrCode as string; // VietQR string from PayOS (EMVCo standard)
    var unpaidFeeId = ViewBag.UnpaidFeeId as int?;
    var unpaidFeeAmount = ViewBag.UnpaidFeeAmount as decimal?;
    var unpaidFeeMonth = ViewBag.UnpaidFeeMonth as int?;
    var unpaidFeeYear = ViewBag.UnpaidFeeYear as int?;
    var payOSNotConfigured = ViewBag.PayOSNotConfigured as bool? ?? false;
}

<style>
    .fee-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s;
    }
    .fee-card:hover {
        border-color: #cbd5e1;
    }
    .fee-card.paid {
        background: #f0fdf4;
        border-color: #bbf7d0;
    }
    .fee-card.unpaid {
        background: #fffbeb;
        border-color: #fde68a;
    }
    .btn-pay-fee {
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 13px;
        transition: background-color 0.2s;
    }
    .btn-pay-fee:hover {
        background-color: #b91c1c;
        color: white;
    }

    /* QR Code styles */
    .qr-container {
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        max-width: 320px;
        margin: 0 auto;
    }
    .qr-container img {
        width: 200px;
        height: 200px;
        border-radius: 8px;
    }
    .qr-amount {
        font-size: 24px;
        font-weight: 800;
        color: #dc2626;
        margin: 12px 0 4px;
    }
    .qr-label {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 16px;
    }
    .qr-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 24px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: background-color 0.2s;
    }
    .qr-link:hover {
        background-color: #b91c1c;
        color: white;
    }
    .qr-countdown {
        font-size: 12px;
        color: #94a3b8;
        margin-top: 8px;
    }
</style>

<div class="mb-4">
    <h3 class="fw-bold" style="color: #0f172a;">Phí sàn</h3>
    <p class="text-muted small">Phí sàn 199,000đ/tháng để duy trì hoạt động trên nền tảng PrintNow.</p>
</div>

@if (isLocked)
{
    <div class="alert alert-danger d-flex align-items-center gap-3 mb-4" style="border-radius: 12px;" role="alert">
        <i class="bi bi-lock-fill fs-4"></i>
        <div>
            <strong class="d-block">Tiệm của bạn đã bị khóa!</strong>
            <span>Vui lòng thanh toán phí sàn để tiếp tục nhận đơn hàng mới.</span>
        </div>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!string.IsNullOrEmpty(checkoutUrl))
{
    <!-- Auto-generated QR Code for unpaid fee -->
    <div class="mb-4">
        <div class="qr-container shadow-sm">
            <div class="mb-2">
                <i class="bi bi-credit-card-2-front" style="font-size: 32px; color: var(--primary);"></i>
            </div>
            <div class="qr-amount">@unpaidFeeAmount?.ToString("N0")₫</div>
            <div class="qr-label">Phí sàn tháng @unpaidFeeMonth/@unpaidFeeYear</div>

            @if (!string.IsNullOrEmpty(qrCode))
            {
                <!-- VietQR từ PayOS - encode EMVCo string vào QR code, quét bằng app ngân hàng được ngay -->
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=@Uri.EscapeDataString(qrCode)"
                     alt="VietQR thanh toán phí sàn"
                     id="qrCodeImg"
                     style="width: 200px; height: 200px; border-radius: 8px;" />
            }
            else
            {
                <!-- Fallback: QR từ checkoutUrl -->
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=@Uri.EscapeDataString(checkoutUrl)"
                     alt="QR thanh toán phí sàn"
                     id="qrCodeImgFallback"
                     style="width: 200px; height: 200px; border-radius: 8px;" />
            }

            <div style="margin-top: 16px;">
                <a href="@checkoutUrl" target="_blank" class="qr-link" id="payNowBtn">
                    <i class="bi bi-credit-card"></i> Thanh toán online
                </a>
            </div>
            <div class="qr-countdown">
                <i class="bi bi-clock me-1"></i>Link thanh toán có hiệu lực trong 24h
            </div>
        </div>
    </div>
}
else if (payOSNotConfigured && Model.Any(f => f.Status == "Unpaid"))
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4" style="border-radius: 12px;" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        <div>
            <strong class="d-block">PayOS chưa được cấu hình!</strong>
            <span>Vui lòng liên hệ Admin để cấu hình cổng thanh toán PayOS trước khi có thể thanh toán phí sàn.</span>
        </div>
    </div>
}

<div class="d-flex flex-column gap-3">
    @foreach (var fee in Model)
    {
        <div class="fee-card @(fee.Status == "Paid" ? "paid" : "unpaid")">
            <div>
                <h6 class="fw-bold mb-1" style="font-size: 15px;">
                    Phí sàn tháng @fee.Month/@fee.Year
                </h6>
                <div class="d-flex align-items-center gap-3" style="font-size: 13px;">
                    <span class="fw-bold text-danger">@fee.Amount.ToString("N0")đ</span>
                    @if (fee.Status == "Paid")
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                        if (fee.PaidAt.HasValue)
                        {
                            <span class="text-muted">@fee.PaidAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        }
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                    }
                </div>
            </div>
            <div>
                @if (fee.Status == "Unpaid" && string.IsNullOrEmpty(checkoutUrl))
                {
                    <button type="button" class="btn-pay-fee" onclick="payFee(@fee.Id)">
                        <i class="bi bi-qr-code me-1"></i> Thanh toán ngay
                    </button>
                }
                else if (fee.Status == "Unpaid" && fee.Id == unpaidFeeId && !string.IsNullOrEmpty(checkoutUrl))
                {
                    <span class="badge bg-info text-white">Đã tạo mã QR</span>
                }
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-receipt fs-1 d-block mb-2"></i>
            <span>Chưa có hóa đơn phí sàn nào.</span>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-refresh payment status when page loads
        $(document).ready(function() {
            @if (!string.IsNullOrEmpty(checkoutUrl))
            {
                <text>
                // Auto-check payment status every 5 seconds
                var checkInterval = setInterval(function() {
                    $.get('/api/PayOS/check-fee-status?feeId=@unpaidFeeId', function(response) {
                        if (response.status === 'PAID' || response.status === 'Completed') {
                            clearInterval(checkInterval);
                            location.reload();
                        }
                    });
                }, 5000);

                // Stop checking after 30 minutes
                setTimeout(function() {
                    clearInterval(checkInterval);
                }, 30 * 60 * 1000);
                </text>
            }
        });

        function payFee(feeId) {
            var btn = event.target.closest('button');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang tạo...';

            $.post('/api/PayOS/create-fee-payment', { feeId: feeId }, function(response) {
                if (response.success) {
                    window.location.href = response.checkoutUrl;
                } else {
                    alert(response.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-qr-code me-1"></i> Thanh toán ngay';
                }
            }).fail(function() {
                alert('Lỗi kết nối. Vui lòng thử lại.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-qr-code me-1"></i> Thanh toán ngay';
            });
        }
    </script>
}
