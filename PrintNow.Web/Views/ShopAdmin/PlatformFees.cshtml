@model List<PrintNow.Web.Models.PlatformFee>
@{
    ViewData["Title"] = "Phí sàn";
    Layout = "_ShopAdminLayout";
    var isLocked = ViewBag.IsLocked as bool? ?? false;
    var payOSNotConfigured = ViewBag.PayOSNotConfigured as bool? ?? false;
}

<style>
    .fee-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s;
    }
    .fee-card:hover {
        border-color: #cbd5e1;
    }
    .fee-card.paid {
        background: #f0fdf4;
        border-color: #bbf7d0;
    }
    .fee-card.unpaid {
        background: #fffbeb;
        border-color: #fde68a;
    }
    .btn-pay-fee {
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 13px;
        transition: background-color 0.2s;
    }
    .btn-pay-fee:hover {
        background-color: #b91c1c;
        color: white;
    }
</style>

<div class="mb-4">
    <h3 class="fw-bold" style="color: #0f172a;">Phí sàn</h3>
    <p class="text-muted small">Phí sàn 199,000đ/tháng để duy trì hoạt động trên nền tảng PrintNow.</p>
</div>

@if (isLocked)
{
    <div class="alert alert-danger d-flex align-items-center gap-3 mb-4" style="border-radius: 12px;" role="alert">
        <i class="bi bi-lock-fill fs-4"></i>
        <div>
            <strong class="d-block">Tiệm của bạn đã bị khóa!</strong>
            <span>Vui lòng thanh toán phí sàn để tiếp tục nhận đơn hàng mới.</span>
        </div>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (payOSNotConfigured && Model.Any(f => f.Status == "Unpaid"))
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4" style="border-radius: 12px;" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        <div>
            <strong class="d-block">PayOS chưa được cấu hình!</strong>
            <span>Vui lòng liên hệ Admin để cấu hình cổng thanh toán PayOS trước khi có thể thanh toán phí sàn.</span>
        </div>
    </div>
}

<div class="d-flex flex-column gap-3">
    @foreach (var fee in Model)
    {
        <div class="fee-card @(fee.Status == "Paid" ? "paid" : "unpaid")">
            <div>
                <h6 class="fw-bold mb-1" style="font-size: 15px;">
                    Phí sàn tháng @fee.Month/@fee.Year
                </h6>
                <div class="d-flex align-items-center gap-3" style="font-size: 13px;">
                    <span class="fw-bold text-danger">@fee.Amount.ToString("N0")đ</span>
                    @if (fee.Status == "Paid")
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                        if (fee.PaidAt.HasValue)
                        {
                            <span class="text-muted">@fee.PaidAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        }
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                    }
                </div>
            </div>
            <div>
                @if (fee.Status == "Unpaid")
                {
                    <button type="button" class="btn-pay-fee" onclick="payFee(@fee.Id, this)">
                        <i class="bi bi-credit-card me-1"></i> Thanh toán ngay
                    </button>
                }
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-receipt fs-1 d-block mb-2"></i>
            <span>Chưa có hóa đơn phí sàn nào.</span>
        </div>
    }
</div>

@section Scripts {
    <script>
        function payFee(feeId, btn) {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang chuyển...';

            $.ajax({
                url: '/api/PayOS/create-fee-payment',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ feeId: feeId }),
                success: function(response) {
                    if (response.success && response.checkoutUrl) {
                        // Redirect directly to PayOS checkout page
                        window.location.href = response.checkoutUrl;
                    } else {
                        alert(response.message || 'Lỗi tạo thanh toán.');
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-credit-card me-1"></i> Thanh toán ngay';
                    }
                },
                error: function() {
                    alert('Lỗi kết nối. Vui lòng thử lại.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-credit-card me-1"></i> Thanh toán ngay';
                }
            });
        }
    </script>
}
