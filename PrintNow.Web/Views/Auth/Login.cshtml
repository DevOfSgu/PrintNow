@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null; // No default layout for login
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrintNow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: var(--secondary-container); /* Light pink background */
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        .auth-card {
            background-color: var(--surface-container-lowest); /* White */
            padding: 48px 40px;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }
        .logo {
            color: var(--primary);
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .logo img {
            height: 32px;
        }
        h1 {
            font-size: 28px;
            font-weight: 700;
            color: var(--on-surface);
            margin-bottom: 8px;
        }
        p.subtitle {
            font-size: 14px;
            color: var(--on-surface-variant);
            margin-bottom: 32px;
            line-height: 1.5;
        }
        .form-group {
            text-align: left;
            margin-bottom: 20px;
        }
        label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--on-surface);
        }
        input.form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #E5E5E5;
            border-radius: 8px;
            font-size: 16px;
            outline: none;
            transition: all 0.2s;
            box-sizing: border-box;
        }
        input.form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-fixed);
        }
        .forgot-password {
            float: right;
            font-size: 12px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }
        .btn-primary {
            width: 100%;
            padding: 14px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
            transition: background-color 0.2s;
        }
        .btn-primary:hover {
            background-color: var(--on-primary-fixed-variant);
        }
        .register-link {
            margin-top: 24px;
            font-size: 14px;
            color: var(--on-surface-variant);
        }
        .register-link a {
            color: var(--primary);
            font-weight: 600;
            text-decoration: none;
        }
        .text-danger {
            color: var(--error);
            font-size: 14px;
            margin-bottom: 16px;
            display: block;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="logo">
            <img src="~/logoapp.png" alt="PrintNow" style="height: 36px; object-fit: contain;" />
        </div>
        <h1>Chào mừng quay trở lại</h1>
        <p class="subtitle">Vui lòng nhập thông tin để truy cập hệ thống PrintNow.</p>

        @if (ViewBag.Error != null)
        {
            <span class="text-danger">@ViewBag.Error</span>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="example@gmail.com" required />
            </div>
            <div class="form-group">
                <label for="password">Mật khẩu</label>
                <a href="#" class="forgot-password">Quên mật khẩu?</a>
                <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn-primary">Đăng nhập &rarr;</button>
        </form>

        <div class="register-link">
            Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a>
        </div>
    </div>
</body>
</html>
