@{
    ViewData["Title"] = "Khám phá";
    Layout = "_CustomerLayout";
}

<div class="row g-4">
    <!-- Cột trái: Danh sách tiệm in -->
    <div class="col-md-5 d-flex flex-column">
        <div class="card border-0 shadow-sm" style="height: calc(100vh - 120px); border-radius: 16px; overflow: hidden;">
            <div class="card-body d-flex flex-column p-4">
                <h4 class="fw-bold mb-1" style="color: var(--on-surface);">Tiệm in gần bạn</h4>
                <p class="text-muted small mb-3">Khám phá các cửa hàng in ấn chuyên nghiệp trong khu vực của bạn.</p>
                
                <div class="d-flex align-items-center gap-2 mb-4">
                    <label class="fw-bold mb-0 text-nowrap" style="font-size: 14px;">Bán kính tìm kiếm (km):</label>
                    <input type="number" id="radiusInput" class="form-control form-control-sm" value="10" min="1" max="100" style="width: 80px;" />
                    <button class="btn btn-sm btn-primary fw-bold" onclick="reloadShops()">Lọc</button>
                </div>
                
                <div id="shopList" class="flex-grow-1 overflow-auto pe-2" style="scrollbar-width: thin;">
                    <div id="loadingMsg" class="text-center text-muted mt-5">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p>Đang lấy vị trí của bạn...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Cột phải: Bản đồ -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm" style="height: calc(100vh - 120px); border-radius: 16px; overflow: hidden;">
            <div id="map" style="width: 100%; height: 100%;"></div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

    <script>
        var map;
        var userMarker;
        var shopMarkers = [];
        var currentLat = 0;
        var currentLng = 0;

        function reloadShops() {
            if (currentLat === 0) return;
            var radius = document.getElementById('radiusInput').value || 10;
            // Xóa markers cũ
            shopMarkers.forEach(m => map.removeLayer(m));
            shopMarkers = [];
            loadNearbyShops(currentLat, currentLng, radius);
        }

        function initMap(lat, lng) {
            currentLat = lat;
            currentLng = lng;
            map = L.map('map', { zoomControl: false }).setView([lat, lng], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);
            
            // Add custom zoom control position if desired (bottom right)
            L.control.zoom({ position: 'bottomright' }).addTo(map);

            // User marker (blue)
            userMarker = L.marker([lat, lng]).addTo(map)
                .bindPopup('<b>Vị trí của bạn</b>').openPopup();

            loadNearbyShops(lat, lng);
        }

        function loadNearbyShops(lat, lng, radius = 10) {
            document.getElementById('shopList').innerHTML = '<div class="text-center text-muted mt-5"><div class="spinner-border text-primary mb-3" role="status"></div><p>Đang tìm kiếm tiệm in...</p></div>';
            
            fetch(`/Customer/GetNearbyShops?lat=${lat}&lng=${lng}&radiusInKm=${radius}`)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('shopList').innerHTML = '';
                    
                    if (data.length === 0) {
                        document.getElementById('shopList').innerHTML = '<p class="text-muted mt-3">Không tìm thấy tiệm in nào gần bạn.</p>';
                        return;
                    }

                    // Shop Icon (Red)
                    var shopIcon = L.icon({
                        iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-red.png',
                        shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
                        iconSize: [25, 41],
                        iconAnchor: [12, 41],
                        popupAnchor: [1, -34],
                        shadowSize: [41, 41]
                    });

                    data.forEach(shop => {
                        // Add marker
                        var marker = L.marker([shop.lat, shop.lng], {icon: shopIcon}).addTo(map)
                            .bindPopup(`<b>${shop.name}</b><br/>${shop.address}<br/><a href="https://www.google.com/maps/dir/?api=1&destination=${shop.lat},${shop.lng}" target="_blank" class="text-primary text-decoration-none fw-bold mt-2 d-inline-block" style="font-size: 12px;"><i class="bi bi-cursor-fill"></i> Chỉ đường</a>`);
                        shopMarkers.push(marker);

                        // Dữ liệu thật từ Controller
                        var rating = shop.rating.toFixed(1);
                        var reviews = shop.reviewCount;
                        var distance = shop.distance.toFixed(1);
                        var shopImageUrl = shop.imageUrl ? shop.imageUrl : "/images/shops/anhmau.jpg";
                        
                        var starColor = reviews > 0 ? "var(--primary)" : "#ccc"; // Màu xám nếu chưa có đánh giá

                        // Add to list
                        var shopHtml = `
                            <div class="card mb-3" style="border: 1px solid #E5E5E5; box-shadow: 0 4px 15px rgba(0,0,0,0.08); border-radius: 12px; cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'" onclick="window.location.href='/Customer/ShopDetail/${shop.id}?lat=${lat}&lng=${lng}'">
                                <div class="card-body p-3 d-flex gap-3">
                                    <div style="width: 80px; height: 80px; background-color: #f0f0f0; border-radius: 8px; overflow: hidden; flex-shrink: 0;">
                                        <img src="${shopImageUrl}" style="width: 100%; height: 100%; object-fit: cover;" alt="Shop Image" />
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-1" style="color: var(--on-surface); font-size: 15px;">${shop.name}</h6>
                                        <div class="d-flex align-items-center mb-1">
                                            <span style="color: ${starColor};" class="me-1">★</span>
                                            <span class="fw-bold me-1" style="font-size: 13px;">${rating}</span>
                                            <span class="text-muted" style="font-size: 12px;">(${reviews} đánh giá)</span>
                                        </div>
                                        <div class="text-muted d-flex justify-content-between align-items-center" style="font-size: 12px;">
                                            <div>
                                                <span class="me-2" style="color: var(--primary);">📍</span>
                                                <span class="me-2">~${distance} km</span>
                                                <span>• Đang mở cửa</span>
                                            </div>
                                            <a href="https://www.google.com/maps/dir/?api=1&destination=${shop.lat},${shop.lng}" target="_blank" onclick="event.stopPropagation();" class="text-primary text-decoration-none fw-bold" style="font-size: 11.5px;">
                                                <i class="bi bi-cursor-fill"></i> Chỉ đường
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                        document.getElementById('shopList').insertAdjacentHTML('beforeend', shopHtml);
                    });
                })
                .catch(error => {
                    console.error('Error fetching shops:', error);
                    document.getElementById('shopList').innerHTML = '<p class="text-danger mt-3">Lỗi khi tải danh sách tiệm in.</p>';
                });
        }

        document.addEventListener('DOMContentLoaded', function () {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    function (position) {
                        var lat = position.coords.latitude;
                        var lng = position.coords.longitude;
                        sessionStorage.setItem("user_lat", lat);
                        sessionStorage.setItem("user_lng", lng);
                        initMap(lat, lng);
                    },
                    function (error) {
                        document.getElementById('loadingMsg').innerHTML = "<p class='text-danger'>Vui lòng cho phép quyền truy cập vị trí.</p>";
                        // Fallback to center of Ho Chi Minh City if location denied
                        sessionStorage.setItem("user_lat", 10.762622);
                        sessionStorage.setItem("user_lng", 10.660172);
                        initMap(10.762622, 106.660172);
                    }
                );
            } else {
                document.getElementById('loadingMsg').innerText = "Trình duyệt của bạn không hỗ trợ định vị (Geolocation).";
            }
        });
    </script>
}
