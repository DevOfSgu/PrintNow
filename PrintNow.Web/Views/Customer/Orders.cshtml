@model IEnumerable<PrintNow.Web.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của bạn";
    Layout = "_CustomerLayout";
}

<div class="container py-2">
    <div class="mb-4">
        <h3 class="fw-bold m-0" style="color: #0f172a;">Đơn hàng của bạn</h3>
        <p class="text-muted small m-0 mt-1">Theo dõi tiến trình in ấn các tài liệu của bạn trong thời gian thực.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        var payMethod = TempData["PaymentMethod"]?.ToString();
        if (payMethod == "MoMo")
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 12px; background: linear-gradient(135deg, #d1fae5, #ecfdf5); border-left: 4px solid #10b981 !important;">
                <div class="d-flex align-items-center gap-3">
                    <img src="/momo.png" alt="MoMo" style="width: 36px; height: 36px; object-fit: contain; border-radius: 8px; flex-shrink: 0;" />
                    <div>
                        <div class="fw-bold" style="color: #065f46;">✅ Thanh toán MoMo thành công!</div>
                        <div class="small" style="color: #047857;">@TempData["SuccessMessage"]</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        else
        {
            <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 12px; background: linear-gradient(135deg, #dbeafe, #eff6ff); border-left: 4px solid #3b82f6 !important;">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-cash-stack fs-3 text-primary" style="flex-shrink: 0;"></i>
                    <div>
                        <div class="fw-bold" style="color: #1e40af;">🎉 Đặt hàng thành công!</div>
                        <div class="small" style="color: #1d4ed8;">@TempData["SuccessMessage"]</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background: linear-gradient(135deg, #fee2e2, #fef2f2); border-left: 4px solid #ef4444 !important;">
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-exclamation-octagon-fill fs-3 text-danger" style="flex-shrink: 0;"></i>
                <div>
                    <div class="fw-bold" style="color: #991b1b;">❌ Lỗi thực hiện</div>
                    <div class="small" style="color: #b91c1c;">@TempData["ErrorMessage"]</div>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5" style="border-radius: 16px;">
            <div class="card-body">
                <div class="mb-4 text-muted" style="font-size: 48px;">
                    <i class="bi bi-file-earmark-bar-graph"></i>
                </div>
                <h5 class="fw-bold mb-2">Chưa có đơn hàng nào</h5>
                <p class="text-muted max-width-500 mx-auto mb-4">Bạn chưa thực hiện bất kỳ đơn đặt in nào. Khám phá các tiệm in xung quanh và cấu hình tài liệu của bạn ngay!</p>
                <a href="/Customer/Index" class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 8px;">Khám phá Tiệm in</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                @foreach (var order in Model)
                {
                    <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; overflow: hidden; border: 1px solid #e2e8f0;">
                        <!-- Header đơn hàng -->
                        <div class="card-header bg-white border-bottom p-4 d-flex flex-wrap align-items-center justify-content-between gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-danger-subtle text-danger rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="bi bi-shop fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold m-0" style="font-size: 16px; color: #1e293b;">@order.Shop.ShopName</h6>
                                    <div class="text-muted" style="font-size: 12px;">
                                        Mã ĐH: <span class="fw-semibold">#ORD-@order.Id</span> &bull; 
                                        Đặt lúc: @order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            </div>
                            <div>
                                @if (order.Status == "Pending")
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill fw-bold" style="font-size: 12px;">
                                        <span class="spinner-grow spinner-grow-sm me-1" role="status" aria-hidden="true" style="animation-duration: 1.2s; width: 8px; height: 8px;"></span>
                                        Chờ xác nhận
                                    </span>
                                }
                                else if (order.Status == "Printing")
                                {
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-bold" style="font-size: 12px;">
                                        <i class="bi bi-printer-fill me-1"></i> Đang in tài liệu
                                    </span>
                                }
                                else if (order.Status == "Ready")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-bold" style="font-size: 12px;">
                                        <i class="bi bi-bookmark-star-fill me-1"></i> Sẵn sàng & Chờ lấy
                                    </span>
                                }
                                else if (order.Status == "Completed")
                                {
                                    <span class="badge bg-success text-white px-3 py-2 rounded-pill fw-bold" style="font-size: 12px;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Hoàn thành
                                    </span>
                                }
                                else if (order.Status == "Cancelled")
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill fw-bold" style="font-size: 12px;">
                                        <i class="bi bi-x-circle-fill me-1"></i> Đã hủy
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Chi tiết file in -->
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                @foreach (var detail in order.OrderDetails)
                                {
                                    <li class="list-group-item p-4 border-bottom">
                                        <div class="d-flex justify-content-between align-items-start gap-3">
                                            <div class="d-flex gap-3">
                                                <div class="text-danger" style="font-size: 28px; line-height: 1;">
                                                    <i class="bi bi-file-earmark-pdf-fill"></i>
                                                </div>
                                                <div>
                                                    <h6 class="fw-bold mb-1" style="font-size: 14px; color: #334155;">@detail.FileName</h6>
                                                    <p class="text-muted mb-0" style="font-size: 12px;">
                                                        Khổ: @detail.PaperSize &bull; 
                                                        @(detail.IsColor ? "In màu" : "Trắng đen") &bull; 
                                                        @detail.Sides mặt &bull; 
                                                        Số lượng: x@(detail.Quantity)
                                                    </p>
                                                    @if (!string.IsNullOrEmpty(detail.AddOnList))
                                                    {
                                                        <div class="mt-2 text-muted fst-italic" style="font-size: 12px; background: #f8fafc; padding: 4px 10px; border-radius: 6px; display: inline-block; border: 1px solid #f1f5f9;">
                                                            <i class="bi bi-chat-left-text me-1"></i> Ghi chú: @detail.AddOnList
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <span class="fw-bold text-dark" style="font-size: 14px;">@detail.SubTotal.ToString("N0") đ</span>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Footer đơn hàng -->
                        <div class="card-footer bg-white border-top p-4">
                            @if (order.Status == "Cancelled")
                            {
                                <div class="alert alert-danger-subtle text-danger border border-danger-subtle p-3 mb-3" style="border-radius: 8px; font-size: 13px;">
                                    <i class="bi bi-info-circle-fill me-2"></i> <strong>Lý do hủy đơn:</strong> @order.CancelReason
                                </div>
                            }
                            
                            <div class="mb-3 pb-3 border-bottom d-flex flex-wrap justify-content-between align-items-center gap-2" style="font-size: 13px;">
                                <div>
                                    <span class="text-muted">Phương thức nhận:</span>
                                    <span class="fw-bold text-dark ms-1">
                                        @if (order.DeliveryMethod == "Delivery")
                                        {
                                            <i class="bi bi-truck text-danger me-1"></i><span>Giao tận nơi</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-shop text-muted me-1"></i><span>Tới lấy tại cửa hàng</span>
                                        }
                                    </span>
                                </div>
                                @if (order.DeliveryMethod == "Delivery")
                                {
                                    <div class="text-end">
                                        <span class="text-muted">Địa chỉ:</span>
                                        <span class="fw-semibold text-dark ms-1">@order.ShippingAddress</span>
                                    </div>
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-muted small">Trạng thái thanh toán:</div>
                                    <span class="fw-bold @(order.PaymentStatus == "Paid" ? "text-success" : "text-warning")" style="font-size: 13px;">
                                        <i class="bi @(order.PaymentStatus == "Paid" ? "bi-cash-coin" : "bi-hourglass-split") me-1"></i>
                                        @(order.PaymentStatus == "Paid" ? "Đã thanh toán" : "Thanh toán khi nhận hàng")
                                    </span>
                                </div>
                                <div class="text-end">
                                    <div class="text-muted small">Tổng thanh toán:</div>
                                    <span class="fs-5 fw-bold text-danger">@order.TotalAmount.ToString("N0") đ</span>
                                    @if (order.ShippingFee > 0)
                                    {
                                        <div class="text-muted small" style="font-size: 11px;">(gồm @order.ShippingFee.ToString("N0")đ phí ship)</div>
                                    }
                                </div>
                            </div>
                            
                            @if (order.Status == "Completed")
                            {
                                <div class="border-top mt-3 pt-3 text-end">
                                    @{
                                        var reviewedOrderIds = ViewBag.ReviewedOrderIds as List<int> ?? new List<int>();
                                        var isReviewed = reviewedOrderIds.Contains(order.Id);
                                    }
                                    @if (!isReviewed)
                                    {
                                        <a href="/Customer/CreateReview?orderId=@order.Id" class="btn btn-sm btn-danger fw-bold shadow-sm" style="border-radius: 8px; padding: 6px 14px;">
                                            <i class="bi bi-star-fill me-1"></i> Đánh giá đơn hàng
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-success small fw-bold">
                                            <i class="bi bi-check-circle-fill me-1"></i> Bạn đã đánh giá đơn hàng này
                                        </span>
                                    }
                                </div>
                            }

                            @if (order.Status == "Pending")
                            {
                                <div class="border-top mt-3 pt-3 text-end">
                                    <form asp-action="CancelOrder" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?');" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold shadow-sm" style="border-radius: 8px; padding: 6px 14px;">
                                            <i class="bi bi-trash3 me-1"></i> Hủy đơn hàng
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Cột bên phải: Hướng dẫn / Liên hệ hỗ trợ -->
            <div class="col-12 col-lg-4 mt-4 mt-lg-0">
                <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 16px; border: 1px solid #e2e8f0;">
                    <h5 class="fw-bold mb-3" style="color: #0f172a;">Quy trình xử lý đơn</h5>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex gap-3">
                            <span class="badge rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; flex-shrink: 0;">1</span>
                            <div>
                                <h6 class="fw-bold mb-1" style="font-size: 14px;">Chờ tiệm nhận đơn</h6>
                                <p class="text-muted small mb-0">Tiệm in sẽ kiểm tra file của bạn và xác nhận đơn hàng sớm nhất.</p>
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <span class="badge rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; flex-shrink: 0;">2</span>
                            <div>
                                <h6 class="fw-bold mb-1" style="font-size: 14px;">Đang tiến hành in</h6>
                                <p class="text-muted small mb-0">Tiệm in tải file và thực hiện in ấn theo đúng yêu cầu cấu hình của bạn.</p>
                            </div>
                        </div>
                        <div class="d-flex gap-3">
                            <span class="badge rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; flex-shrink: 0;">3</span>
                            <div>
                                <h6 class="fw-bold mb-1" style="font-size: 14px;">Nhận hàng tại tiệm</h6>
                                <p class="text-muted small mb-0">Khi trạng thái đổi thành "Sẵn sàng", hãy di chuyển tới tiệm in để nhận tài liệu.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm p-4 text-center bg-danger-subtle border border-danger-subtle text-danger" style="border-radius: 16px;">
                    <i class="bi bi-chat-dots-fill fs-3 mb-2 d-block"></i>
                    <h6 class="fw-bold">Bạn có thắc mắc về đơn hàng?</h6>
                    <p class="small text-muted mb-3" style="color: #64748b !important;">Hãy nhắn tin trực tiếp với tiệm in để thảo luận thêm về yêu cầu in ấn.</p>
                    <a href="/Customer/Messages" class="btn btn-sm btn-danger fw-bold w-100" style="border-radius: 8px;">Nhắn tin ngay</a>
                </div>
            </div>
        </div>
    }
</div>
