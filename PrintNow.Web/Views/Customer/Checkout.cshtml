@model PrintNow.Web.Models.Order
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    Layout = "_CustomerLayout";
}

<style>
    .checkout-title {
        font-size: 22px;
        font-weight: 700;
        color: #0f172a;
    }
    
    .checkout-section-title {
        font-size: 15px;
        font-weight: 700;
        color: #334155;
        margin-top: 32px;
        margin-bottom: 16px;
    }

    .selector-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 24px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        background: white;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }
    
    .selector-card.selected {
        border: 2px solid var(--primary);
        box-shadow: 0 4px 12px rgba(214, 40, 57, 0.04);
    }
    
    .selector-card:hover:not(.selected) {
        border-color: #cbd5e1;
    }

    .payos-logo {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #1890ff, #096dd9);
        color: white;
        border-radius: 8px;
        font-weight: 900;
        font-size: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-confirm-checkout {
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 14px;
        font-weight: 700;
        font-size: 16px;
        width: 100%;
        margin-top: 24px;
        transition: background-color 0.2s;
    }
    .btn-confirm-checkout:hover {
        background-color: var(--on-primary-fixed-variant);
        color: white;
    }

    .btn-confirm-checkout:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .payment-loading {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 48px 32px;
        text-align: center;
        margin-top: 24px;
    }
</style>

<div class="container py-2" style="max-width: 960px;">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <span class="text-muted small">Thanh toán đơn hàng #PN-@Model.Id</span>
        <a href="/Customer/Cart" class="text-decoration-none text-muted small"><i class="bi bi-chevron-left"></i> Quay lại giỏ hàng</a>
    </div>

    <div id="checkoutForm">
        <input type="hidden" id="orderId" value="@Model.Id" />
        
        <h4 class="checkout-title">Thanh toán đơn hàng</h4>

        <!-- Tóm tắt đơn hàng -->
        <div class="card border-0 shadow-sm mt-4" style="border-radius: 16px; border: 1px solid #e2e8f0;">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color: #475569; font-size: 14px;">Tóm tắt đơn hàng</h6>
                
                <!-- Danh sách file in -->
                <div class="mb-4">
                    @foreach (var detail in Model.OrderDetails)
                    {
                        <div class="d-flex align-items-center justify-content-between py-3 border-bottom">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; flex-shrink: 0;">
                                    <i class="bi bi-file-earmark-pdf-fill text-danger fs-3"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold m-0" style="font-size: 14px; color: #1e293b;">@detail.FileName</h6>
                                    <span class="text-muted" style="font-size: 12px;">
                                        Khổ: @detail.PaperSize &bull; @(detail.IsColor ? "In màu" : "Trắng đen") &bull; @detail.Sides mặt &bull; Số lượng: x@detail.Quantity
                                    </span>
                                </div>
                            </div>
                            <span class="fw-bold" style="font-size: 14px; color: #1e293b;">@detail.SubTotal.ToString("N0")đ</span>
                        </div>
                    }
                </div>

                <!-- Tính tiền -->
                <div class="d-flex flex-column gap-2" style="font-size: 14px;">
                    <div class="d-flex justify-content-between text-muted">
                        <span>Tạm tính:</span>
                        <span class="fw-semibold text-dark">@Model.TotalAmount.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted">
                        <span>Phí vận chuyển:</span>
                        <span class="fw-semibold text-dark" id="shippingFeeText">0đ</span>
                    </div>
                    <div class="d-flex justify-content-between border-top pt-3 mt-1">
                        <span class="fw-bold" style="font-size: 15px;">Tổng thanh toán:</span>
                        <span class="fw-bold text-danger fs-5" id="totalAmountText" data-subtotal="@Model.TotalAmount">@Model.TotalAmount.ToString("N0")đ</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Phương thức nhận hàng -->
        <h6 class="checkout-section-title">Phương thức nhận hàng</h6>
        <input type="hidden" id="deliveryMethodInput" value="Pickup" />
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <div class="selector-card" id="card-delivery" onclick="selectDeliveryMethod('Delivery')">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="text-danger fs-4 mt-1"><i class="bi bi-truck"></i></div>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-2" style="font-size: 15px;">Giao tận nơi</h6>
                            <input type="text" class="form-control form-control-sm mt-2" id="shippingAddressInput" 
                                   placeholder="Nhập địa chỉ giao hàng của bạn..." onclick="event.stopPropagation()" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="selector-card selected" id="card-pickup" onclick="selectDeliveryMethod('Pickup')">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="text-danger fs-4 mt-1"><i class="bi bi-shop"></i></div>
                        <div>
                            <h6 class="fw-bold mb-2" style="font-size: 15px;">Tới lấy tại cửa hàng</h6>
                            <p class="text-muted small mb-0">Địa chỉ tiệm: @Model.Shop.AddressText</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Phương thức thanh toán - PayOS only -->
        <h6 class="checkout-section-title">Phương thức thanh toán</h6>
        <div class="row g-3">
            <div class="col-12">
                <div class="selector-card selected" id="card-payos">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="payos-logo">PayOS</div>
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size: 15px;">Chuyển khoản ngân hàng (PayOS)</h6>
                            <p class="text-muted small mb-0">Bạn sẽ được chuyển đến cổng thanh toán PayOS để quét mã QR và hoàn tất thanh toán.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nút xác nhận và thanh toán -->
        <button type="button" class="btn-confirm-checkout" id="btnPayNow">
            <i class="bi bi-credit-card me-2"></i> Xác nhận & Thanh toán
        </button>

        <!-- Loading state -->
        <div class="payment-loading" id="paymentLoading" style="display: none;">
            <div class="spinner-border text-danger mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
            <h6 class="fw-bold mb-1">Đang chuyển đến cổng thanh toán...</h6>
            <p class="text-muted small mb-0">Vui lòng chờ trong giây lát.</p>
        </div>
    </div>
</div>

<script>
    const subtotal = @Html.Raw(Model.TotalAmount);
    const shippingFeeVal = 20000;
    const orderId = @Model.Id;

    function selectDeliveryMethod(method) {
        document.getElementById('deliveryMethodInput').value = method;
        
        const cardPickup = document.getElementById('card-pickup');
        const cardDelivery = document.getElementById('card-delivery');
        const addressInput = document.getElementById('shippingAddressInput');
        const shippingFeeText = document.getElementById('shippingFeeText');
        const totalAmountText = document.getElementById('totalAmountText');

        if (method === 'Delivery') {
            cardPickup.classList.remove('selected');
            cardDelivery.classList.add('selected');
            addressInput.required = true;
            shippingFeeText.innerText = formatCurrency(shippingFeeVal);
            totalAmountText.innerText = formatCurrency(subtotal + shippingFeeVal);
        } else {
            cardDelivery.classList.remove('selected');
            cardPickup.classList.add('selected');
            addressInput.required = false;
            addressInput.value = '';
            shippingFeeText.innerText = '0đ';
            totalAmountText.innerText = formatCurrency(subtotal);
        }
    }

    function formatCurrency(value) {
        return value.toLocaleString('vi-VN') + 'đ';
    }

    document.getElementById('btnPayNow').addEventListener('click', function() {
        const btn = this;
        const method = document.getElementById('deliveryMethodInput').value;
        const address = document.getElementById('shippingAddressInput').value.trim();
        
        if (method === 'Delivery' && address === '') {
            alert('Vui lòng nhập địa chỉ giao hàng của bạn.');
            return;
        }

        // Show loading and disable button
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...';
        document.getElementById('paymentLoading').style.display = 'block';

        // Update order with delivery info
        const orderData = {
            orderId: orderId,
            deliveryMethod: method,
            shippingAddress: method === 'Delivery' ? address : null,
            paymentMethod: 'PayOS'
        };

        $.post('/Customer/UpdateOrderInfo', orderData, function(response) {
            if (!response.success) {
                alert(response.message || 'Lỗi cập nhật đơn hàng.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-credit-card me-2"></i> Xác nhận & Thanh toán';
                document.getElementById('paymentLoading').style.display = 'none';
                return;
            }

            // Create PayOS payment and redirect to checkout URL
            $.ajax({
                url: '/api/PayOS/create-order-payment',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ orderId: orderId }),
                success: function(paymentResponse) {
                    if (paymentResponse.success && paymentResponse.checkoutUrl) {
                        // Redirect directly to PayOS checkout page
                        window.location.href = paymentResponse.checkoutUrl;
                    } else {
                        alert(paymentResponse.message || 'Lỗi tạo thanh toán.');
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-credit-card me-2"></i> Xác nhận & Thanh toán';
                        document.getElementById('paymentLoading').style.display = 'none';
                    }
                },
                error: function() {
                    alert('Lỗi kết nối đến PayOS. Vui lòng thử lại.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-credit-card me-2"></i> Xác nhận & Thanh toán';
                    document.getElementById('paymentLoading').style.display = 'none';
                }
            });
        }).fail(function() {
            alert('Lỗi kết nối. Vui lòng thử lại.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-credit-card me-2"></i> Xác nhận & Thanh toán';
            document.getElementById('paymentLoading').style.display = 'none';
        });
    });
</script>
