@model PrintNow.Web.Models.Shop
@{
    ViewData["Title"] = Model.ShopName;
    var distanceText = ViewBag.Distance > 0 ? $"Cách bạn ~{ViewBag.Distance}km" : "Chưa xác định khoảng cách";
    var shopImageUrl = !string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "/images/shops/anhmau.jpg";
    
    var reviews = Model.Reviews.ToList();
    var avgRating = reviews.Any() ? reviews.Average(r => r.Rating) : 0;
    var totalReviews = reviews.Count;
}

<div class="container py-4">
    <!-- Nút quay lại -->
    <a href="/Customer/Index" class="btn btn-danger mb-4 d-inline-block fw-bold" style="border-radius: 8px;">
        <i class="bi bi-arrow-left me-1"></i> Về trang chủ
    </a>

    <div class="row g-4">
        <!-- Cột trái: Thông tin chính & Bảng giá -->
        <div class="col-lg-8">
            <!-- Thông tin chính -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid #E5E5E5;">
                <div class="card-body p-4 d-flex align-items-center gap-4">
                    <div style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                        <img src="@shopImageUrl" alt="Logo" style="width: 100%; height: 100%; object-fit: cover;" />
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <h4 class="fw-bold mb-0" style="color: var(--on-surface);">@Model.ShopName</h4>
                            @if (Model.IsActive)
                            {
                                <span class="badge" style="background-color: #E6F4EA; color: #137333; font-weight: 500;">ĐANG MỞ CỬA</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">ĐÓNG CỬA</span>
                            }
                        </div>
                        <p class="text-muted mb-3">
                            <i class="bi bi-geo-alt me-1"></i> @distanceText &bull; Phục vụ nhanh chóng
                            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                            {
                                <a href="https://www.google.com/maps/dir/?api=1&destination=@Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),@Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)" target="_blank" class="ms-2 text-primary text-decoration-none fw-semibold" style="font-size: 13.5px;">
                                    <i class="bi bi-cursor-fill me-1"></i> Chỉ đường
                                </a>
                            }
                        </p>
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <p class="text-secondary small mb-3" style="max-width: 600px;">@Model.Description</p>
                        }
                        <a href="/Customer/OrderConfig/@Model.Id" class="btn btn-primary px-4 fw-bold" style="border-radius: 8px;"><i class="bi bi-printer me-2"></i> Đặt in ngay</a>
                        <a href="/Customer/Messages?shopId=@Model.Id" class="btn btn-outline-primary px-4 fw-bold ms-2" style="border-radius: 8px;"><i class="bi bi-chat-left-dots me-2"></i> Nhắn tin</a>
                    </div>
                </div>
            </div>

            <!-- Bảng giá -->
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid #E5E5E5;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0" style="color: var(--on-surface);">Bảng giá dịch vụ</h5>
                        <i class="bi bi-receipt fs-4 text-muted"></i>
                    </div>
                    
                    <ul class="list-group list-group-flush">
                        @if (Model.Services.Any(s => s.IsActive))
                        {
                            foreach (var s in Model.Services.Where(s => s.IsActive))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom">
                                    <span style="font-weight: 500;">@s.ServiceName</span>
                                    <span class="fw-bold" style="color: var(--primary);">@s.BasePrice.ToString("N0")đ <small class="text-muted fw-normal">/@s.Unit</small></span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center py-4 text-muted border-bottom-0">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                Chưa có bảng giá dịch vụ
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Đánh giá khách hàng -->
            <div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid #E5E5E5;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0" style="color: var(--on-surface);">Đánh giá khách hàng</h5>
                        <div class="text-end">
                            <span class="fs-4 fw-bold text-warning me-1"><i class="bi bi-star-fill"></i> @avgRating.ToString("0.0")</span>
                            <span class="text-muted">(@totalReviews đánh giá)</span>
                        </div>
                    </div>

                    <div class="row g-3">
                        @if (reviews.Any())
                        {
                            foreach (var r in reviews)
                            {
                                <div class="col-md-6">
                                    <div class="p-3 border rounded" style="background-color: #fafafa;">
                                        <div class="d-flex justify-content-between mb-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 13px;">
                                                    @r.Customer.FullName.Substring(0, 1).ToUpper()
                                                </div>
                                                <span class="fw-bold" style="font-size: 13.5px;">@r.Customer.FullName</span>
                                            </div>
                                            <div class="text-warning" style="font-size: 13px;">
                                                @for (int i = 0; i < r.Rating; i++)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                                @for (int i = r.Rating; i < 5; i++)
                                                {
                                                    <i class="bi bi-star text-muted"></i>
                                                }
                                            </div>
                                        </div>
                                        <p class="text-muted mb-0 fst-italic" style="font-size: 13px; white-space: pre-line;">@r.Comment</p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-center py-4 text-muted">
                                <i class="bi bi-chat-square-text fs-3 d-block mb-2"></i>
                                Chưa có đánh giá nào cho tiệm in này
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Liên hệ -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm" style="border-radius: 16px; border: 1px solid #E5E5E5;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 d-flex align-items-center gap-2" style="color: var(--on-surface);">
                        <i class="bi bi-info-circle text-danger"></i> Thông tin liên hệ
                    </h5>
                    
                    <div class="d-flex gap-3 mb-4">
                        <i class="bi bi-map fs-5 text-muted"></i>
                        <div>
                            <p class="mb-0 text-muted" style="line-height: 1.6;">@Model.AddressText</p>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-3 mb-4">
                        <i class="bi bi-clock fs-5 text-muted"></i>
                        <div>
                            <p class="mb-0 text-muted" style="line-height: 1.6;">@(Model.OperatingHoursText ?? "08:00 - 22:00 (Thứ 2 - Chủ Nhật)")</p>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-3">
                        <i class="bi bi-telephone fs-5 text-muted"></i>
                        <div>
                            <p class="mb-0 text-muted" style="line-height: 1.6;">@(Model.Owner?.Phone ?? "0909 123 456")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
